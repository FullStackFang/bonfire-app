# Supabase transaction pooler (Settings -> Database -> Connection string -> Transaction)
DATABASE_URL=postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-us-east-1.pooler.supabase.com:6543/postgres
# DB pool size per process. Serverless prod: leave unset (defaults to 1 — many instances share the
# pooler). Local dev: set 5 so page loads and polls don't queue behind one connection.
PG_POOL_MAX=5
# Public base URL of this deployment (no trailing slash)
APP_BASE_URL=http://localhost:3000
# Shared secret for /api/cron/tick (also a GitHub Actions secret)
CRON_SECRET=change-me
# Twilio (leave SMS_DRY_RUN=1 until launch day)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=+1xxxxxxxxxx
SMS_DRY_RUN=1
# Vercel AI Gateway (plan proposer). Local: create a key in the Vercel dashboard (AI Gateway ->
# API Keys), or `vercel env pull` for a ~24h VERCEL_OIDC_TOKEN. Deployed on Vercel: automatic via
# OIDC, no key needed. Without a credential the proposer uses deterministic fallback options.
AI_GATEWAY_API_KEY=
# Gateway model slug: provider-prefixed, dotted versions (e.g. anthropic/claude-sonnet-5,
# anthropic/claude-opus-4.8, openai/gpt-5.4). Optional — defaults to anthropic/claude-sonnet-5.
PLAN_AI_MODEL=anthropic/claude-sonnet-5
# Geocoder (server-side only) — resolves a pulse's free-text place to a map coordinate at
# creation. All optional: defaults to keyless Nominatim/OSM so it works with no config. Map tiles
# are keyless (Carto Voyager), so NO tile key is ever needed. Any key stays server-side.
#   GEOCODER_URL          Nominatim-compatible endpoint (default: OSM public Nominatim)
#   GEOCODER_KEY          API key, sent as ?key= for a keyed Nominatim-compatible provider
#   GEOCODER_USER_AGENT   identifying UA/contact (Nominatim policy)
#   GEOCODER_TIMEOUT_MS   per-call timeout before giving up (default 2500)
#   GEOCODER_DISABLED=1   force the no-op: never geocode, stylized tile everywhere, no requests
GEOCODER_URL=
GEOCODER_KEY=
GEOCODER_USER_AGENT=
GEOCODER_TIMEOUT_MS=2500
GEOCODER_DISABLED=

# Admin review area (/admin) — gated on phone-OTP identity + this allowlist. A viewer is an admin
# iff phone-verified AND their E.164 number is listed here. Comma-separated E.164, no spaces
# (e.g. +14165550101,+14165550102). Unset/empty => nobody is an admin and /admin 404s (fail closed).
ADMIN_PHONES=
