{
  "expo": {
    "name": "Bonfire",
    "slug": "bonfire",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "bonfire",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.fullstackfang.bonfire",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Bonfire shows you on the map for friends to find. We only know where you are while the app is open.",
        "NSContactsUsageDescription": "We match your contacts to find friends already on Bonfire. Your address book never leaves your device — only one-way hashes."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0a0a0c",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.fullstackfang.bonfire"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0a0a0c",
          "dark": {
            "backgroundColor": "#0a0a0c"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
